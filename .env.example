# Next.js / Nexus-Agent environment
# Copy values into .env.local for local development.

# Prisma runtime URL (Neon pooled connection recommended)
# Example: postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15
DATABASE_URL=

# Python runtime URL (Neon direct connection recommended for psycopg2)
# Example: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
PYTHON_DATABASE_URL=

# Required by Python agent runtime (scripts/agents/agent_builder.py)
GOOGLE_API_KEY=your_google_api_key_here

# Optional: set a specific Python executable if `python` is not on PATH
# Examples:
# Windows: C:\\Python311\\python.exe
# macOS/Linux: /usr/bin/python3
PYTHON_EXECUTABLE=python
