generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id             Int        @id @default(autoincrement())
  name           String     @unique
  description    String?
  agentType      String     @map("agent_type")
  modelConfig    Json?      @map("model_config")
  tools          Json?
  systemPrompt   String?    @map("system_prompt")
  maxRetries     Int?       @map("max_retries")
  timeoutSeconds Int?       @map("timeout_seconds")
  createdAt      DateTime?  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime?  @default(now()) @map("updated_at") @db.Timestamp(6)
  states         AgentState[]
  audits         AuditLog[]

  @@map("agents")
}

model Workflow {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  description String?
  definition  Json
  creatorId   String?     @map("creator_id")
  version     Int?        @default(1)
  isActive    Boolean?    @default(true) @map("is_active")
  createdAt   DateTime?   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime?   @default(now()) @map("updated_at") @db.Timestamp(6)
  executions  Execution[]

  @@map("workflows")
}

model Execution {
  id          Int          @id @default(autoincrement())
  workflowId  Int?         @map("workflow_id")
  executionId String?      @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("execution_id")
  status      String?      @default("pending")
  inputData   Json?        @map("input_data")
  outputData  Json?        @map("output_data")
  errorMessage String?     @map("error_message")
  startedAt   DateTime?    @map("started_at") @db.Timestamp(6)
  completedAt DateTime?    @map("completed_at") @db.Timestamp(6)
  createdAt   DateTime?    @default(now()) @map("created_at") @db.Timestamp(6)
  workflow    Workflow?    @relation(fields: [workflowId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  states      AgentState[]
  audits      AuditLog[]

  @@index([workflowId], map: "idx_executions_workflow")
  @@index([status], map: "idx_executions_status")
  @@map("executions")
}

model AgentState {
  id          Int        @id @default(autoincrement())
  executionId Int?       @map("execution_id")
  agentId     Int?       @map("agent_id")
  stepNumber  Int?       @map("step_number")
  state       Json
  memory      Json?
  createdAt   DateTime?  @default(now()) @map("created_at") @db.Timestamp(6)
  execution   Execution? @relation(fields: [executionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  agent       Agent?     @relation(fields: [agentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([executionId], map: "idx_agent_states_execution")
  @@map("agent_states")
}

model AuditLog {
  id          Int        @id @default(autoincrement())
  executionId Int?       @map("execution_id")
  agentId     Int?       @map("agent_id")
  action      String?
  details     Json?
  userId      String?    @map("user_id")
  timestamp   DateTime?  @default(now()) @db.Timestamp(6)
  execution   Execution? @relation(fields: [executionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  agent       Agent?     @relation(fields: [agentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([executionId], map: "idx_audit_logs_execution")
  @@index([agentId], map: "idx_audit_logs_agent")
  @@index([timestamp], map: "idx_audit_logs_timestamp")
  @@map("audit_logs")
}

model Tool {
  id              Int       @id @default(autoincrement())
  name            String    @unique
  description     String?
  category        String?
  schema          Json
  handlerFunction String?   @map("handler_function")
  isEnabled       Boolean?  @default(true) @map("is_enabled")
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("tools")
}
